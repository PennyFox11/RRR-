  m_Script: {fileID: 11500000, guid: e16a06b8c639a1b4892d54b4dbb60bdd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTriggerMaria
  dialogue:
    name: Maria the Maid
    sentences:
    - hmm...hmm...AH! Signora Rose, you scared me! I'm sure you're back to save poor
      Iris.
    - Well you must be careful. Those damn hounds are all over. You must avoid being
      seen by them.
    - If you get noticed, you'll have 10 seconds to run away from them before they
      alert the guards.
    - The guards have the keys you will need to free Iris from the room Armando's
      keeping her in.
    - When fighting the guards, if your health gets too low, run to the bathroom
      and heal yourself with the first aid kit.
    - Also Signora! Be sure to collect all the diamonds scattered around the floor.
      Better to collect your alimony a little early ;)
