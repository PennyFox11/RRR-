  m_Script: {fileID: 11500000, guid: 31e74839a77332149860eae206eb912e, type: 3}
  m_Name: MariaDialogue
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  npcName: Maria the Maid
  npcPortrait: {fileID: 21300000, guid: c7b93966ac246da47910d8519b1f7bf8, type: 3}
  dialogueLines:
  - Hmm..hmm..AH! Signora Rose you scared me!
  - I'm sure you've come back for poor Iris. Well you must be careful.
  - There are hounds all over. Avoid being seen by them.
  - If you do get noticed, you'll have 5 seconds to get away from them before they
    alert the guards.
  - There is a guard just across the wing. Defeat him to get a key, that key will
    be needed to free Iris.
  - If you get injured during combat, there's a first aid kit in the bathroom.
  - 'ALSO Signora, collect the diamonds scattered in some of the rooms. '
  - It doesn't to collect your alimony a little early, right? ;)
  autoProgressLines: 0101010101010101
